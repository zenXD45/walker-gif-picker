#!/usr/bin/env python3
import sys
import subprocess
import urllib.request
import io
from PIL import Image

def notify(title, msg):
    subprocess.Popen(["notify-send", "-t", "3000", f"󰾆 {title}", msg])

def main():
    if len(sys.argv) < 2:
        sys.exit(1)

    url = sys.argv[1].split(" ")[0]
    if not url.startswith("http"):
        sys.exit(1)

    try:
        # Fetch the GIF directly into memory (no file downloaded to disk!)
        req = urllib.request.Request(url, headers={'User-Agent': 'Mozilla/5.0'})
        with urllib.request.urlopen(req, timeout=10) as response:
            image_data = response.read()

        # Load into Pillow to extract static image payload
        image = Image.open(io.BytesIO(image_data))
        
        # Convert first frame to RGBA/RGB PNG bytes in memory
        image = image.convert("RGBA")
        png_io = io.BytesIO()
        image.save(png_io, format="PNG")
        png_bytes = png_io.getvalue()

        # Pipe the PNG image payload directly to Wayland clipboard
        # We use image/png because image/gif causes Elephant to crash with infinite filename looping.
        # This perfectly mimics Windows "Copy Image" behavior: direct image payload, no downloading!
        subprocess.run(["wl-copy", "-t", "image/png"], input=png_bytes, timeout=5)
        
        notify("Image Copied!", "Ready to paste directly into Element/WhatsApp.")
        
    except Exception as e:
        subprocess.run(["wl-copy", url], timeout=5)
        notify("Image Fetch Failed", f"Fallback to URL: {str(e)}")

if __name__ == "__main__":
    main()
